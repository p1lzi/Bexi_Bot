DISCORD_TOKEN = "your_token_here"  ## The token for your Discord bot, obtained from the Discord Developer Portal. This is required for the bot to authenticate with the Discord API and operate. Keep this token secret and do not share it with anyone, as it grants full access to your bot's functionality. If this token is compromised, you should regenerate it immediately in the Discord Developer Portal.
DEFAULT_LANG=en  ## Default language for the bot, used when no language is specified in the command. Supported values: en, de
DEBUG=false  ## Set to true to enable debug logging. This will log all incoming messages and commands, as well as any errors that occur. Useful for troubleshooting and development. Set to false in production to reduce log noise.