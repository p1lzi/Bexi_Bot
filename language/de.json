    "commands": {
        "setup_pioneer_role": {
            "description": "Vergibt automatisch eine Pionier-Rolle an die ersten 100 Mitglieder",
            "params": {
                "rolle": "Die Rolle, die an die ersten 100 beigetretenen Mitglieder vergeben wird"
            }
        },
        "selfrole_erstellen": {
            "description": "Startet den interaktiven Einrichtungs-Assistenten für ein Self-Role Panel",
            "params": {}
        },
        "selfrole_loeschen": {
            "description": "Löscht ein bestehendes Self-Role Panel anhand der Nachrichten-ID",
            "params": {
                "panel_id": "Nachrichten-ID des Panels (Rechtsklick → ID kopieren)"
            }
        },
        "selfrole_liste": {
            "description": "Zeigt alle aktiven Self-Role Panels dieses Servers",
            "params": {}
        },
        "whitelist": {
            "description": "Verwaltet die Liste der erlaubten Link-Domains",
            "params": {
                "aktion": "Aktion auswählen: Hinzufügen, Entfernen oder Liste anzeigen",
                "domain": "Domain ohne https://, z.B. youtube.com"
            },
            "choices": {
                "aktion": {
                    "add": "Hinzufügen",
                    "remove": "Entfernen",
                    "list": "Liste anzeigen"
                }
            }
        },
        "ban": {
            "description": "Bannt ein Mitglied permanent vom Server",
            "params": {
                "nutzer": "Das Mitglied, das gebannt werden soll",
                "grund": "Grund für den Bann (wird per DM mitgeteilt)"
            }
        },
        "kick": {
            "description": "Kickt ein Mitglied vom Server",
            "params": {
                "nutzer": "Das Mitglied, das gekickt werden soll",
                "grund": "Grund für den Kick (wird per DM mitgeteilt)"
            }
        },
        "timeout": {
            "description": "Versetzt ein Mitglied für eine bestimmte Zeit in den Timeout",
            "params": {
                "nutzer": "Das Mitglied, das in den Timeout versetzt werden soll",
                "minuten": "Dauer in Minuten, z.B. 10",
                "grund": "Grund für den Timeout (wird per DM mitgeteilt)"
            }
        },
        "warn": {
            "description": "Verwarnt ein Mitglied und speichert den Warn",
            "params": {
                "nutzer": "Das Mitglied, das verwarnt werden soll",
                "grund": "Grund für die Verwarnung (wird per DM mitgeteilt)"
            }
        },
        "warn_edit": {
            "description": "Bearbeitet oder löscht die Verwarnungen eines Nutzers",
            "params": {
                "nutzer": "Das Mitglied, dessen Warns bearbeitet werden",
                "anzahl": "Neue Gesamtanzahl der Verwarnungen (0 = alle löschen)"
            }
        },
        "userinfo": {
            "description": "Zeigt Infos zu einem Mitglied — Admins können andere einsehen",
            "params": {
                "nutzer": "Nur Admins: Mitglied einsehen (leer = eigene Infos)"
            }
        },
        "set_log_channel": {
            "description": "Legt den Kanal für Moderations-Logs fest",
            "params": {
                "kanal": "Textkanal, in dem alle Moderationsaktionen protokolliert werden"
            }
        },
        "set_welcome_channel": {
            "description": "Legt den Kanal für Willkommensnachrichten fest",
            "params": {
                "kanal": "Textkanal, in dem neue Mitglieder begrüßt werden"
            }
        },
        "set_waiting_room": {
            "description": "Konfiguriert den Warteraum für die Support-Musik",
            "params": {
                "kanal": "Sprachkanal, in dem Support-Musik abgespielt wird"
            }
        },
        "setup_verify": {
            "description": "Startet den interaktiven Einrichtungs-Assistenten für ein Verifizierungs-Panel",
            "params": {}
        },
        "status_config": {
            "description": "Startet den interaktiven Bot-Status-Wizard",
            "params": {},
            "choices": {
                "status": {
                    "online": "Online",
                    "idle": "Abwesend (Idle)",
                    "dnd": "Bitte nicht stören (DnD)",
                    "invisible": "Unsichtbar (Offline)"
