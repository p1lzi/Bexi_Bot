        "set_language": {
            "description": "Ändert die Sprache aller Bot-Texte und Embeds",
            "params": {
                "sprache": "Sprachcode: 'de' für Deutsch, 'en' für Englisch"
            }
        },
        "ping": {
            "description": "Zeigt die aktuelle Bot-Latenz an",
            "params": {}
        },
        "setup_application": {
            "description": "Startet den interaktiven Einrichtungs-Assistenten für ein Bewerbungs-Panel",
            "params": {}
        },
        "application_delete": {
            "description": "Löscht ein bestehendes Bewerbungs-Panel",
