                "aktivitaet_typ": {
                    "playing": "Spielt",
                    "streaming": "Streamt",
                    "listening": "Hört zu",
                    "watching": "Schaut"
                }
            }
        },
        "setup_tickets": {
            "description": "Startet den interaktiven Einrichtungs-Assistenten für ein Ticket-Panel",
            "params": {}
        },
        "ticket_edit": {
            "description": "Bearbeitet ein bestehendes Ticket-Panel",
            "params": {
                "message_id": "ID der Panel-Nachricht (Autocomplete verfügbar)",
                "titel": "Neuer Titel (leer = unverändert)",
                "beschreibung": "Neuer Beschreibungstext (leer = unverändert)",
